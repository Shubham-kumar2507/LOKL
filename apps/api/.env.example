# ── Required ────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/lokl
REDIS_URL=redis://localhost:6379
JWT_SECRET=super_secret_dev_key_123
NODE_ENV=development

# ── Email Verification ──────────────────────────────────
# Set to 'true' to require verification, 'false' otherwise
REQUIRE_EMAIL_VERIFICATION=false

# SMTP configuration for verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@lokl.app

# ── Optional (media uploads) ───────────────────────────
S3_BUCKET=lokl-media
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Server ─────────────────────────────────────────────
PORT=3001

# ── Frontend URLs (used by CORS and CSP) ───────────────
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

